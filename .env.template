# ENVIRONMENT VARIABLES TEMPLATE
# For Local Development: Copy to .env.local
# For AWS Amplify: Set in Amplify Console environment variables

# ============================================
# REQUIRED - AI & Content Generation
# ============================================
# Get from: https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-your_anthropic_api_key_here
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ============================================
# REQUIRED - WhatsApp/Twilio Configuration
# ============================================
# Get these from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=AC_your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WEBHOOK_TOKEN=any_random_verification_token

# ============================================
# REQUIRED - Admin Authentication
# ============================================
# These are used for admin dashboard login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here_min_8_chars

# JWT Secret (generate a random string, min 32 chars)
JWT_SECRET=your_super_secret_jwt_key_generate_random_string_here_min_32_chars

# ============================================
# OPTIONAL - Telegram Bot Configuration
# ============================================
# Get from BotFather on Telegram (@BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_telegram_webhook_secret_here

# ============================================
# OPTIONAL - Development Settings
# ============================================
# Uncomment for verbose logging in development
# DEBUG=true
# NODE_ENV=development

# Claude/Anthropic Configuration
# Get this from https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-your_claude_api_key_here
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# === SETUP GUIDE FOR WHATSAPP ===
# 1. Create a Twilio account at https://www.twilio.com
# 2. Go to Console > Messaging > Try it out > Send a WhatsApp message
# 3. Copy your ACCOUNT_SID and AUTH_TOKEN
# 4. Get a Twilio WhatsApp sandbox number (or your own)
# 5. In Twilio Dashboard, set webhook URL to:
#    http://your-domain.com/api/webhooks/whatsapp
# 6. Set webhook to POST method

# === SETUP GUIDE FOR TELEGRAM ===
# 1. Create a bot with @BotFather on Telegram
# 2. Copy the bot token
# 3. Set your bot webhook URL to:
#    http://your-domain.com/api/webhooks/telegram
# 4. Run: curl -X POST https://api.telegram.org/bot<TOKEN>/setWebhook \
#         -H "Content-Type: application/json" \
#         -d '{"url":"http://your-domain.com/api/webhooks/telegram"}'

# === SETUP GUIDE FOR OPENAI ===
# 1. Create an account at https://platform.openai.com
# 2. Go to API keys page and create a new secret key
# 3. Copy the key here
# 4. Make sure you have billing set up

# === ADMIN LOGIN ===
# Admin Dashboard URL: http://localhost:3000/admin
# Default credentials: admin / (password from ADMIN_PASSWORD above)
# Change credentials in first login!
